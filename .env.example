## Copy this file to `.env` and update values for your deployment

# Secret used to sign JWTs (change to a secure random value in production)
SECRET_KEY=change-this-secret-key

# JWT expiry (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Comma-separated list of allowed origins for CORS. Use '*' to allow all (not recommended).
ALLOWED_ORIGINS=http://localhost:5173,http://localhost

# Backend port
BACKEND_PORT=8001
